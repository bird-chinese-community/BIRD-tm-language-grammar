# Normalize line endings: check out as LF, commit as LF.
# Prevents CRLF/LF churn (e.g. grammar JSON edited on Windows).
* text=auto eol=lf

# Explicit LF for text source/types the repo owns.
*.json   text eol=lf
*.vim    text eol=lf
*.sh     text eol=lf
*.js     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.md     text eol=lf
*.cjs    text eol=lf
*.toml   text eol=lf

# Submodule contents are managed by their own repos; do not touch.
external/** linguist-vendored

# Binary assets — never normalize.
*.png  binary
*.jpg  binary
*.ico  binary
