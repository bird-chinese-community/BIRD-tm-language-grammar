root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{sh,vim}]
indent_style = space
indent_size = 4

[*.md]
# Preserve two trailing spaces for hard line breaks in Markdown.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
